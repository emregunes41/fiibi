generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhotographyPackage {
  id           String        @id @default(cuid())
  name         String
  description  String
  price        String
  category     String        @default("STANDARD")
  timeType     String        @default("FULL_DAY")
  maxCapacity  Int           @default(1)
  features     String[]
  addons       Json?
  customFields Json?
  availableSlots Json?
  deliveryTimeDays Int           @default(14)
  postSelectionDays Int          @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[] @relation("PhotographyPackageToReservation")
}

model Reservation {
  id             String               @id @default(cuid())
  brideName      String
  bridePhone     String
  brideEmail     String
  groomName      String?
  groomPhone     String?
  groomEmail     String?
  eventDate      DateTime
  eventTime      String?
  status         String               @default("PENDING")
  contractLog    String?
  paymentStatus  String               @default("UNPAID")
  totalAmount    String?
  paidAmount     String?
  selectedAddons     Json?
  customFieldAnswers Json?
  paymentPreference  String?            // CASH or CARD
  notes              String?
  venueName          String?
  paymentLogs        Json?
  contractApproved   Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  userId         String?
  selectedPhotos String?
  selectionLocked Boolean              @default(false)
  workflowStatus String               @default("PENDING")
  deliveryDate   DateTime?
  deliveryLink   String?
  user           User?                @relation(fields: [userId], references: [id])
  gallery        PhotoGallery?
  packages       PhotographyPackage[] @relation("PhotographyPackageToReservation")
  albumModelId   String?
  albumModel     AlbumModel?          @relation(fields: [albumModelId], references: [id])
  payments       Payment[]
}

model Payment {
  id            String      @id @default(cuid())
  reservationId String
  amount        Float
  method        String      // CASH, BANK_TRANSFER, CREDIT_CARD, ONLINE
  note          String?
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  password      String?
  emailVerified DateTime?
  image         String?
  gender        String?
  age           Int?
  phone         String?
  role          String        @default("MEMBER")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  purchases     Purchase[]
  reservations  Reservation[]
  sessions      Session[]
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  productName  String
  productType  String
  price        String
  purchaseDate DateTime @default(now())
  status       String   @default("COMPLETED")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhotoGallery {
  id              String      @id @default(cuid())
  reservationId   String      @unique
  reservation     Reservation @relation(fields: [reservationId], references: [id])
  photos          Photo[]
  isDelivered     Boolean     @default(false)
  deliveredAt     DateTime?
  selectionLimit  Int         @default(50)
  createdAt       DateTime    @default(now())
}

model Photo {
  id           String       @id @default(cuid())
  galleryId    String
  gallery      PhotoGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photoNumber  Int
  originalName String?      // Changed from photoNumber implicitly, or adding it alongside. Let me re-read plan. "Orijinal isim alanı ekle". We can keep photoNumber if needed for sorting, but add originalName.
  url          String
  isSelected   Boolean      @default(false)
  createdAt    DateTime     @default(now())
}

model AdminNotification {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO") // SELECTION_DONE, REMINDER vb.
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AlbumModel {
  id          String        @id @default(cuid())
  name        String
  description String?
  imageUrl    String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  reservations Reservation[]
}

model PortfolioCategory {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  createdAt DateTime         @default(now())
  photos    PortfolioPhoto[]
}

model PortfolioPhoto {
  id          String            @id @default(cuid())
  url         String
  publicId    String?
  categoryId  String
  category    PortfolioCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
}

model MonthlyPriceConfig {
  id                 String   @id @default(cuid())
  category           String   // DIŞ ÇEKİM, DÜĞÜN, NİŞAN gibi
  month              Int      // 1-12
  year               Int      // 2024, 2025 vb.
  minPrice           Int?     // Opsiyonel taban fiyat
  discountPercentage Int      @default(0) // -10: %10 indirim, 10: %10 zam
  updatedAt          DateTime @updatedAt

  @@unique([category, month, year])
}

model GlobalSettings {
  id           String   @id @default("global-settings")
  heroTitle    String   @default("Anları Sanata Dönüştürüyoruz")
  heroSubtitle String   @default("Premium Photography Service")
  address      String   @default("Moda, Kadıköy / İstanbul")
  phone        String   @default("+90 555 000 00 00")
  email        String   @default("hello@pinowed.com")
  instagram    String   @default("")
  whatsapp     String   @default("")
  cashPromoText String  @default("")
  heroBgType   String   @default("video")
  heroBgUrl    String   @default("/assets/hero.mp4")
  heroBgColor  String   @default("#000000")
  // Sözleşme
  contractText String   @default("")
  // Bildirim kanalları
  emailEnabled Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  // Resend API (E-posta)
  resendApiKey    String @default("")
  // Netgsm API (SMS)
  netgsmUsercode  String @default("")
  netgsmPassword  String @default("")
  netgsmMsgHeader String @default("")
  // Bildirim tercihleri (hangileri gönderilsin)
  notifyReservation  Boolean @default(true)
  notifyPayment      Boolean @default(true)
  notifyReminder     Boolean @default(true)
  notifyPhotosReady  Boolean @default(true)
  googleMapsUrl  String   @default("")
  // AI Chatbot
  chatbotEnabled      Boolean @default(true)
  chatbotInstructions String  @default("")
  updatedAt    DateTime @updatedAt
}

model DiscountCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int      // e.g. 10 = %10
  isActive        Boolean  @default(true)
  maxUses         Int      @default(0)   // 0 = unlimited
  usedCount       Int      @default(0)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  mediaType String   @default("image") // "image" or "video"
  title     String?
  subtitle  String?
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentBlock {
  id          String   @id @default(cuid())
  title       String?
  description String?
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
