generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PhotographyPackage {
  id           String        @id @default(cuid())
  name         String
  description  String
  price        String
  category     String        @default("STANDARD")
  timeType     String        @default("FULL_DAY")
  maxCapacity  Int           @default(1)
  features     String[]
  addons       Json?
  deliveryTimeDays Int           @default(14)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[] @relation("PhotographyPackageToReservation")
}

model Reservation {
  id             String               @id @default(cuid())
  brideName      String
  bridePhone     String
  brideEmail     String
  groomName      String?
  groomPhone     String?
  groomEmail     String?
  eventDate      DateTime
  eventTime      String?
  status         String               @default("PENDING")
  contractLog    String?
  paymentStatus  String               @default("UNPAID")
  totalAmount    String?
  paidAmount     String?
  selectedAddons Json?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  userId         String?
  workflowStatus String               @default("PENDING")
  deliveryDate   DateTime?
  user           User?                @relation(fields: [userId], references: [id])
  gallery        PhotoGallery?
  packages       PhotographyPackage[] @relation("PhotographyPackageToReservation")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  password      String?
  emailVerified DateTime?
  image         String?
  gender        String?
  age           Int?
  phone         String?
  role          String        @default("MEMBER")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  purchases     Purchase[]
  reservations  Reservation[]
  sessions      Session[]
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  productName  String
  productType  String
  price        String
  purchaseDate DateTime @default(now())
  status       String   @default("COMPLETED")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhotoGallery {
  id              String      @id @default(cuid())
  reservationId   String      @unique
  reservation     Reservation @relation(fields: [reservationId], references: [id])
  photos          Photo[]
  isDelivered     Boolean     @default(false)
  deliveredAt     DateTime?
  selectionLimit  Int         @default(50)
  createdAt       DateTime    @default(now())
}

model Photo {
  id          String       @id @default(cuid())
  galleryId   String
  gallery     PhotoGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  photoNumber Int
  url         String
  isSelected  Boolean      @default(false)
  createdAt   DateTime     @default(now())
}
